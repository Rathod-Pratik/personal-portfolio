{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ESNext"
    ],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "types": [
      "vite/client"
    ],
    "strict": true,
    "noEmit": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@apiClient": [
        "src/lib/api-Client"
      ],
      "@api": [
        "src/API/index.ts"
      ],
      "@component": [
        "src/Component/index.ts"
      ],
      "@pages": [
        "src/Pages"
      ],
      "@store": [
        "src/store/index.ts"
      ],
      "@store/*": [
        "src/store/*"
      ],
      "@component/*": [
        "src/Component/*"
      ],
      "@api/*": [
        "src/API/*"
      ],
      "@routes/*": [
        "src/Routes/*"
      ],
      "@utils": [
        "src/Utils"
      ],
      "@utils/*": [
        "src/Utils/*"
      ],
      "@pages/*": [
        "src/Pages/*"
      ],
      "@Type": [
        "src/Type/index.ts"
      ],
      "@Type/*": [
        "src/Type/*"
      ],
      "@types/*": [
        "src/Type/*"
      ],
    }
  },
  "include": [
    "src"
  ]
}